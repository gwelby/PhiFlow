{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QSOP Objective Packet",
  "type": "object",
  "required": [
    "objective_id",
    "origin",
    "target",
    "intent",
    "status",
    "created_at",
    "payload_path",
    "checksum"
  ],
  "properties": {
    "objective_id": {
      "type": "string",
      "pattern": "^OBJ-[0-9]{8}-[0-9]{3,}$"
    },
    "origin": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "string",
      "minLength": 1
    },
    "intent": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["pending", "in_progress", "completed", "blocked", "cancelled"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "payload_path": {
      "type": "string",
      "minLength": 1
    },
    "checksum": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "ownership": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "verification_required": {
      "type": "boolean"
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "urgent"]
    }
  },
  "additionalProperties": true
}
